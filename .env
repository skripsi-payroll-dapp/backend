PORT=3001

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# access token:  15 min expiry (NFR-2)
# refresh token: 7 day expiry  (NFR-2)
JWT_SECRET=0d2d06e9be7d4b8a209dc30dd3fc007ae0b2e555a2b11dc52c74c1dbbefc76dd37ea29a76b171f984cd9b3c4579d6fd77df271e2bc8c5e9b3c495740e930f233
JWT_REFRESH_SECRET=44d706d531daa2b1435db4f9918650111364a0e559efc6b1d9057278acb25a0504f78bc6b4fef73b2c261e26b3553bde27cee60fe33bc51c9aa87378915e7877

# Same PostgreSQL as Ponder — backend reads Ponder tables + writes app.* tables
DATABASE_URL=postgresql://payrolladmin:Jeketi48%21@payroll-db-skripsi.postgres.database.azure.com:5432/postgres?sslmode=require

# Pimlico bundler API key — https://dashboard.pimlico.io
PIMLICO_API_KEY=your_pimlico_api_key

# Base Sepolia bundler RPC
BUNDLER_RPC_URL=https://api.pimlico.io/v2/base-sepolia/rpc?apikey=your_pimlico_api_key

# Alchemy webhook signing key — verify incoming webhook payloads
ALCHEMY_WEBHOOK_KEY=your_alchemy_webhook_key


# Owner Address for admin operations (e.g. loan liquidation)
OWNER_ADDRESS=0x906B34db1a8DD333ff9a84255e4AEc13C054f120

# Payroll contract addresses (same as ponder/.env.local)
PAYROLL_CONTRACT_ADDRESS=0x0B4BDD8fF3f9a76CA67bD16d3b25A0922A3D1Fb5
LIQUIDITY_CONTRACT_ADDRESS=0x50fcAc62A081a6212BF947298a18BdC6d1BFde4A
SBT_CONTRACT_ADDRESS=0x009a7A5E0aFC42BE1b28d5b1907F6A32b1602e3E
IDRX_ADDRESS=0x18Bc5bcC660cf2B9cE3cd51a404aFe1a0cBD3C22

# Rate limiter
MAX_CLAIMS_PER_HOUR=10

# Paymaster monitoring (FR-B02)
# ERC-4337 Paymaster contract address on Base — fill in after deployment
PAYMASTER_ADDRESS=0x0000000000000000000000000000000000000000
# Minimum ETH balance before ops alert fires (0.05 ETH in wei)
PAYMASTER_ALERT_THRESHOLD_ETH=0.05
# Base RPC for read-only calls (can reuse Bundler URL or set a dedicated Alchemy endpoint)
BASE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/WIgWTUMrjNtCwDuUXsv3L

# Ops alert webhook — POST target for Paymaster low-balance alerts (Slack / PagerDuty)
OPS_ALERT_WEBHOOK_URL=

# Ops wallet private key — used by liquidation cron to call liquidateLoan()
OPS_PRIVATE_KEY=your_ops_wallet_private_key

# Application level encryption key for UU PDP PII data protection (AES-256-GCM)
ENCRYPTION_KEY=1e7b8f9e6a7c4f8d2b9e6c8a7d4f9b8c2e7b8f9e6a7c4f8d2b9e6c8a7d4f9b8c
